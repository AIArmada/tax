{
    "name": "aiarmada/tax",
    "description": "Tax calculation engine for the AIArmada Commerce ecosystem",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "laravel",
        "commerce",
        "tax",
        "vat",
        "gst",
        "sales-tax"
    ],
    "authors": [
        {
            "name": "AIArmada",
            "email": "dev@aiarmada.com"
        }
    ],
    "require": {
        "aiarmada/commerce-support": "self.version",
        "akaunting/laravel-money": "^6.0.3",
        "owen-it/laravel-auditing": "^14.0.3",
        "php": "^8.4",
        "spatie/laravel-activitylog": "^5.0.0",
        "spatie/laravel-data": "^4.23.0",
        "spatie/laravel-model-states": "^2.14.1",
        "spatie/laravel-settings": "^3.8.1"
    },
    "autoload": {
        "psr-4": {
            "AIArmada\\Tax\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AIArmada\\Tax\\TaxServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
